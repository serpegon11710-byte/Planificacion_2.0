# ==========================================
# Clean Onion Documentation (COD) - Template
# Canonical Universal .gitignore
# ==========================================

# --- AGENT CONFIGURATION (TOKEN PROTECTION) ---
# Temporary files generated by agents during script execution
*.tmp
*.temp
tmp/
temp/

# --- OPERATING SYSTEM ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- SOURCE CODE & DEPENDENCIES ---
# Node / Javascript
node_modules/
jspm_packages/
.npm
.eslintcache
.stylelintcache
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/

# --- DEVELOPMENT ENVIRONMENTS (IDEs) ---
# VS Code / Cursor / Claude Code
.vscode/*
!.vscode/extensions.json
.cursor/history/
.claude/

# --- BUILD, DIST & PRODUCTION ---
dist/
build/
out/
.next/
.nuxt/

# --- SECURITY & SECRETS ---
# Strict block for local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key